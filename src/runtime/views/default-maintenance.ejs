<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= appName %> | Maintenance</title>
  <style>
    :root {
      --bg: #f5f1e8;
      --ink: #1f1a17;
      --muted: #63564e;
      --card: rgba(255, 255, 255, 0.94);
      --line: rgba(31, 26, 23, 0.08);
      --accent: #b5552d;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
      background:
        radial-gradient(circle at 10% 0%, rgba(181, 85, 45, 0.12) 0%, transparent 32%),
        radial-gradient(circle at 100% 100%, rgba(99, 86, 78, 0.14) 0%, transparent 30%),
        var(--bg);
      color: var(--ink);
      font-family: "Avenir Next", Avenir, "Segoe UI", sans-serif;
    }

    .shell {
      width: min(760px, 100%);
      background: var(--card);
      border: 1px solid var(--line);
      box-shadow: 0 24px 80px rgba(31, 26, 23, 0.08);
      padding: 28px 24px;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 18px;
      padding: 7px 11px;
      border: 1px solid rgba(181, 85, 45, 0.18);
      background: rgba(181, 85, 45, 0.08);
      color: #7a3518;
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      flex-shrink: 0;
    }

    h1 {
      margin: 0 0 14px;
      font-size: clamp(30px, 4.4vw, 44px);
      line-height: 1.1;
      letter-spacing: -0.03em;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 16px;
    }

    .meta {
      margin-top: 22px;
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    .meta-item {
      padding: 12px 14px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.8);
    }

    .meta-label {
      margin: 0;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #846f63;
    }

    .meta-value {
      margin: 6px 0 0;
      font-size: 16px;
      font-weight: 650;
      color: var(--ink);
      word-break: break-word;
    }

    footer {
      margin-top: 18px;
      font-size: 13px;
      color: #7b6e67;
    }
  </style>
</head>
<body>
  <main class="shell">
    <div class="eyebrow">
      <span class="dot"></span>
      Maintenance Mode
    </div>

    <h1>We&apos;ll be back soon.</h1>
    <p><%= appName %> is temporarily unavailable while maintenance is in progress.</p>

    <div class="meta">
      <section class="meta-item">
        <p class="meta-label">Environment</p>
        <p class="meta-value"><%= env %></p>
      </section>
      <section class="meta-item">
        <p class="meta-label">Requested Path</p>
        <p class="meta-value"><%= requestPath %></p>
      </section>
      <section class="meta-item">
        <p class="meta-label">Status</p>
        <p class="meta-value"><%= statusCode %></p>
      </section>
      <% if (retryAfter) { %>
      <section class="meta-item">
        <p class="meta-label">Retry After</p>
        <p class="meta-value"><%= retryAfter %></p>
      </section>
      <% } %>
    </div>

    <footer>Copyright <%= nowYear %> AegisNode</footer>
  </main>
</body>
</html>
