<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= appName %> | AegisNode</title>
  <style>
    :root {
      --bg: #f2f5f8;
      --ink: #122031;
      --muted: #4a5a6d;
      --card: #ffffff;
      --line: #dbe4ee;
      --accent: #1473e6;
      --accent-soft: #e9f2ff;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Avenir Next", Avenir, "Segoe UI", sans-serif;
      color: var(--ink);
      background:
        radial-gradient(circle at 10% 0%, #dce9ff 0%, transparent 36%),
        radial-gradient(circle at 100% 100%, #d4ffe6 0%, transparent 32%),
        var(--bg);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .shell {
      width: min(860px, 100%);
      border: 1px solid var(--line);
      border-radius: 20px;
      overflow: hidden;
      background: var(--card);
      box-shadow: 0 22px 64px rgba(17, 35, 58, 0.12);
    }

    .head {
      padding: 20px 24px;
      border-bottom: 1px solid var(--line);
      background:
        linear-gradient(135deg, #ffffff 0%, #f8fbff 55%, #f2f8ff 100%);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid #c9ddfb;
      background: var(--accent-soft);
      font-size: 12px;
      color: #0c4e9a;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      font-weight: 700;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #18a957;
      box-shadow: 0 0 0 4px #dcf7e8;
      flex-shrink: 0;
    }

    .body {
      padding: 28px 24px 22px;
    }

    h1 {
      margin: 0 0 12px;
      line-height: 1.2;
      font-size: clamp(28px, 4vw, 40px);
      letter-spacing: -0.02em;
    }

    p {
      margin: 0;
      color: var(--muted);
      line-height: 1.65;
      font-size: 16px;
    }

    .meta {
      margin-top: 22px;
      display: grid;
      gap: 10px;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    }

    .meta-item {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 12px 14px;
      background: #fbfdff;
    }

    .meta-label {
      margin: 0;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #687a90;
    }

    .meta-value {
      margin: 4px 0 0;
      font-size: 16px;
      font-weight: 650;
      color: var(--ink);
      word-break: break-word;
    }

    .cmd {
      margin-top: 18px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 12px;
      border: 1px solid #cadef7;
      background: #f4f9ff;
      color: #21466e;
      font-size: 14px;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    footer {
      border-top: 1px solid var(--line);
      padding: 14px 24px 16px;
      font-size: 13px;
      color: #6d7f95;
      background: #fcfdff;
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="head">
      <div class="badge">
        <span class="dot"></span>
        Framework Online
      </div>
      <strong>AegisNode</strong>
    </header>

    <section class="body">
      <h1>Install Confirmed</h1>
      <p>
        Your project is running correctly with AegisNode. This page is the default fallback for <code>/</code>.
        Define your own <code>route.get('/')</code> in <code>routes.js</code> to replace it.
      </p>

      <div class="meta">
        <article class="meta-item">
          <p class="meta-label">Project</p>
          <p class="meta-value"><%= appName %></p>
        </article>
        <article class="meta-item">
          <p class="meta-label">Environment</p>
          <p class="meta-value"><%= env %></p>
        </article>
      </div>

      <div class="cmd"><%= createAppCommand %></div>
    </section>

    <footer>Copyright <%= nowYear %> AegisNode</footer>
  </main>
</body>
</html>
